# Copy to .env and adjust. Never commit the real .env file.

# --- Storage backend ---
# One of: postgres, mongo
CRP_STORAGE_BACKEND=postgres

CRP_POSTGRES_DSN=postgresql+psycopg://crp:crp@localhost:5432/crp
CRP_MONGO_URI=mongodb://localhost:27017
CRP_MONGO_DB=crp

# --- Scraping ---
# Hard requirement: the pipeline refuses to hit a URL that robots.txt disallows
# unless CRP_RESPECT_ROBOTS=0 is explicitly set (NOT recommended).
CRP_RESPECT_ROBOTS=1
CRP_REQUEST_DELAY_SECONDS=2.0
CRP_MAX_CONCURRENCY=2
CRP_USER_AGENT_ROTATE=1
CRP_OFFLINE_FIXTURES=1

# Optional proxy URL (e.g. http://user:pass@proxy.example:8080)
CRP_HTTP_PROXY=

# --- Celery / Redis ---
CRP_CELERY_BROKER_URL=redis://localhost:6379/0
CRP_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# --- Analysis ---
# baseline | bert
CRP_SENTIMENT_BACKEND=baseline
CRP_BERT_MODEL=uer/roberta-base-finetuned-jd-binary-chinese

# --- Logging ---
CRP_LOG_LEVEL=INFO
